                        </svg>
                    </div>
                    <span class="font-display text-2xl font-bold gradient-text">AI Market</span>
                </div>
                
                <div class="hidden md:flex space-x-8">
                    <a href="#dashboard" class="text-gray-300 hover:text-white transition-colors font-medium">Dashboard</a>
                    <a href="#crypto" class="text-gray-300 hover:text-white transition-colors font-medium">Kripto</a>
                    <a href="#stocks" class="text-gray-300 hover:text-white transition-colors font-medium">Aksiyalar</a>
                    <a href="#analysis" class="text-gray-300 hover:text-white transition-colors font-medium">AI Tahlil</a>
                    <a href="#economic" class="text-gray-300 hover:text-white transition-colors font-medium">Iqtisodiyot</a>
                </div>

                <div class="flex items-center space-x-4">
