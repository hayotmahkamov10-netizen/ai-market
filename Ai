    <script>
        // Initialize Charts
        let mainChart, sentimentChart;
        
        // Sample data for demonstration
        const cryptoData = [
            { name: 'Bitcoin', symbol: 'BTC', price: 67432.00, change24h: 5.2, change7d: 12.4, volume: '34.2B', marketCap: '1.32T', color: 'green' },
            { name: 'Ethereum', symbol: 'ETH', price: 3521.80, change24h: -2.1, change7d: 8.7, volume: '15.8B', marketCap: '423B', color: 'red' },
            { name: 'Solana', symbol: 'SOL', price: 148.50, change24h: 8.4, change7d: 22.1, volume: '4.2B', marketCap: '65B', color: 'green' },
            { name: 'Cardano', symbol: 'ADA', price: 0.68, change24h: -1.2, change7d: 5.3, volume: '892M', marketCap: '24B', color: 'red' },
            { name: 'Polkadot', symbol: 'DOT', price: 9.24, change24h: 3.7, change7d: 15.2, volume: '456M', marketCap: '12B', color: 'green' },
        ];

        // Initialize Main Chart
        function initMainChart() {
            const ctx = document.getElementById('mainChart').getContext('2d');
            const gradient = ctx.createLinearGradient(0, 0, 0, 400);
            gradient.addColorStop(0, 'rgba(99, 102, 241, 0.3)');
            gradient.addColorStop(1, 'rgba(99, 102, 241, 0)');

            mainChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['00:00', '04:00', '08:00', '12:00', '16:00', '20:00', 'Hozir'],
                    datasets: [{
                        label: 'BTC/USDT',
                        data: [65200, 65800, 64500, 66200, 66800, 67100, 67432],
                        borderColor: '#6366f1',
                        backgroundColor: gradient,
                        borderWidth: 3,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 0,
                        pointHoverRadius: 6
                    }, {
                        label: 'ETH/USDT',
                        data: [3400, 3450, 3380, 3500, 3480, 3510, 3521],
                        borderColor: '#8b5cf6',
                        borderWidth: 2,
                        fill: false,
                        tension: 0.4,
                        pointRadius: 0,
                        pointHoverRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        intersect: false,
                        mode: 'index'
                    },
                    plugins: {
                        legend: {
                            display: true,
                            labels: { color: '#9ca3af' }
                        }
                    },
                    scales: {
                        x: {
                            grid: { color: 'rgba(75, 85, 99, 0.2)' },
                            ticks: { color: '#9ca3af' }
                        },
                        y: {
                            grid: { color: 'rgba(75, 85, 99, 0.2)' },
                            ticks: { color: '#9ca3af' }
                        }
                    }
                }
            });
        }

        // Initialize Sentiment Chart
        function initSentimentChart() {
            const ctx = document.getElementById('sentimentChart').getContext('2d');
            sentimentChart = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Sotib olish', 'Neytral', 'Sotish'],
                    datasets: [{
                        data: [65, 20, 15],
                        backgroundColor: ['#10b981', '#6b7280', '#ef4444'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: '#9ca3af', padding: 20 }
                        }
                    }
                }
            });
        }

        // Populate Crypto Table
        function populateCryptoTable() {
            const tbody = document.getElementById('cryptoTable');
            tbody.innerHTML = cryptoData.map(coin => `
                <tr class="hover:bg-gray-800/30 transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="flex items-center">
                            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-${coin.color}-500 to-${coin.color}-600 flex items-center justify-center text-white font-bold text-xs mr-3">
                                ${coin.symbol[0]}
                            </div>
                            <div>
                                <div class="text-sm font-medium text-white">${coin.name}</div>
                                <div class="text-xs text-gray-500">${coin.symbol}</div>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-white">
                        $${coin.price.toLocaleString()}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right">
                        <span class="text-sm ${coin.change24h >= 0 ? 'text-green-400' : 'text-red-400'}">
                            ${coin.change24h >= 0 ? '+' : ''}${coin.change24h}%
                        </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right">
                        <span class="text-sm ${coin.change7d >= 0 ? 'text-green-400' : 'text-red-400'}">
                            ${coin.change7d >= 0 ? '+' : ''}${coin.change7d}%
                        </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-400">
                        ${coin.volume}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-400">
                        ${coin.marketCap}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-center">
                        <div class="flex items-center justify-center space-x-1 h-8">
                            ${Array(7).fill(0).map((_, i) => `
                                <div class="w-1 bg-${coin.color}-500 rounded-full" style="height: ${Math.random() * 20 + 10}px"></div>
                            `).join('')}
                        </div>
                    </td>
                </tr>
            `).join('');
        }

        // Live Ticker
        function updateTicker() {
            const ticker = document.getElementById('liveTicker');
            const items = [
                { symbol: 'BTC', price: '$67,432', change: '+5.2%', positive: true },
                { symbol: 'ETH', price: '$3,521', change: '-2.1%', positive: false },
                { symbol: 'SOL', price: '$148.50', change: '+8.4%', positive: true },
                { symbol: 'AAPL', price: '$178.23', change: '+1.2%', positive: true },
                { symbol: 'TSLA', price: '$202.45', change: '-0.8%', positive: false },
                { symbol: 'NVDA', price: '$875.30', change: '+3.5%', positive: true },
                { symbol: 'GOOGL', price: '$142.60', change: '+0.5%', positive: true },
                { symbol: 'AMZN', price: '$178.90', change: '-1.1%', positive: false },
            ];
            
            const content = items.map(item => `
                <div class="ticker-item">
                    <span class="font-bold text-white">${item.symbol}</span>
                    <span class="text-gray-400 ml-2">${item.price}</span>
                    <span class="${item.positive ? 'text-green-400' : 'text-red-400'} ml-2">${item.change}</span>
                </div>
            `).join('');
            
            ticker.innerHTML = content + content; // Duplicate for seamless loop
        }

        // Simulate live price updates
        function simulateLivePrices() {
            setInterval(() => {
                const btcPrice = document.getElementById('btcPrice');
                const ethPrice = document.getElementById('ethPrice');
                const spxPrice = document.getElementById('spxPrice');
                
                // Random small fluctuations
                const btc = 67432 + (Math.random() - 0.5) * 100;
                const eth = 3521 + (Math.random() - 0.5) * 10;
                const spx = 5234 + (Math.random() - 0.5) * 5;
                
                btcPrice.textContent = '$' + btc.toFixed(2);
                ethPrice.textContent = '$' + eth.toFixed(2);
                spxPrice.textContent = spx.toFixed(2);
            }, 3000);
        }

        // Timeframe buttons
        function updateTimeframe(frame) {
            document.querySelectorAll('.timeframe-btn').forEach(btn => {
                btn.classList.remove('bg-primary', 'text-white');
                btn.classList.add('bg-gray-800', 'text-gray-400');
            });
            event.target.classList.remove('bg-gray-800', 'text-gray-400');
            event.target.classList.add('bg-primary', 'text-white');
            
            // Update chart data based on timeframe
            updateChartData(frame);
        }

        function updateChartData(frame) {
            // Simulate different data for different timeframes
            const multipliers = { '1D': 1, '1W': 7, '1M': 30, '1Y': 365 };
            const multiplier = multipliers[frame];
            
            const newData = mainChart.data.datasets[0].data.map(val => 
                val + (Math.random() - 0.5) * 1000 * multiplier * 0.01
            );
            
            mainChart.data.datasets[0].data = newData;
            mainChart.update();
        }

        function changeChartType(type) {
            mainChart.config.type = type === 'candle' ? 'bar' : 'line';
            mainChart.update();
        }

        function scrollToSection(id) {
            document.getElementById(id).scrollIntoView({ behavior: 'smooth' });
        }

        function showDemo() {
            alert('Demo rejimi: Bu yerda video qo\'llanma yoki interaktiv demo bo\'lishi mumkin');
        }

        function toggleTheme() {
            document.documentElement.classList.toggle('dark');
        }

        // Initialize everything
        document.addEventListener('DOMContentLoaded', () => {
            initMainChart();
            initSentimentChart();
            populateCryptoTable();
            updateTicker();
            simulateLivePrices();
        });

        // Add smooth scroll behavior
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });
    </script>
